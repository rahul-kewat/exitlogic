# Get a free key at https://web3forms.com — add your Gmail there, then paste the access key here for local dev.
# For GitHub Pages: add the same value as repository secret WEB3FORMS_ACCESS_KEY (see deploy workflow).
VITE_WEB3FORMS_ACCESS_KEY=

# Razorpay (https://razorpay.com) — the SECRET key must never go in the frontend. Deploy workers/razorpay-api.js
# (e.g. Cloudflare Worker), set RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, RAZORPAY_AMOUNT_PAISE, RAZORPAY_CURRENCY there,
# then put the public worker URL here (no trailing slash). Key ID is returned from /create-order; do not commit secrets.
# Example: VITE_RAZORPAY_ORDER_API_URL=https://exitlogic-razorpay.your-subdomain.workers.dev
VITE_RAZORPAY_ORDER_API_URL=
